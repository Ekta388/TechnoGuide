# Production Backend Environment Variables
NODE_ENV=production
PORT=5000

# Database (Replace with your Atlas URI)
MONGODB_URI=mongodb+srv://...

# Security
JWT_SECRET=your_long_random_production_secret
CORS_ORIGIN=http://100.x.y.z # Replace with your VPN IP

# WhatsApp (From Meta Developer Dashboard)
WHATSAPP_API_KEY=your_key
WHATSAPP_PHONE_NUM_ID=your_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_id

# Email
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
